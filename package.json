{
  "name": "advanced-pv-calculator",
  "private": true,
  "version": "3.0.0",
  "description": "Advanced PV System Calculator with standalone and hosted build artifacts.",
  "scripts": {
    "build": "node scripts/build_artifacts.js",
    "build:check": "node scripts/build_artifacts.js --check",
    "backend:serve": "node backend/server.js",
    "backend:check": "node backend/server.js --check",
    "bundle:free-static": "node scripts/export_free_static_bundle.js",
    "ops:check:premium": "node scripts/premium_ops_readiness.js",
    "ops:check:premium:strict": "node scripts/premium_ops_readiness.js --strict",
    "release:gate:free": "node scripts/release_gate.js free",
    "release:gate:free:full": "node scripts/release_gate.js free --full",
    "release:gate:premium": "node scripts/release_gate.js premium",
    "release:gate:premium:full": "node scripts/release_gate.js premium --full",
    "serve": "python3 serve.py --build",
    "serve:no-browser": "python3 serve.py --build --no-browser",
    "typecheck": "tsc -p tsconfig.json",
    "test:build": "node _test_build_outputs.js",
    "test:free-bundle": "node _test_free_static_bundle.js",
    "test:deploy-templates": "node _test_deployment_templates.js",
    "test:syntax": "node _test_syntax.js",
    "test:global": "node _test_v3_global.js",
    "test:backend-admin": "node _test_backend_admin_console.js",
    "test:backend-security": "node _test_backend_security.js",
    "test:backend-sqlite": "node --experimental-sqlite _test_backend_sqlite.js",
    "test:backend-backup": "node --experimental-sqlite _test_backend_backup_restore.js",
    "test:backend-retention": "node _test_backend_backup_prune.js",
    "test:premium-ops": "node _test_premium_ops_readiness.js",
    "test:commercial": "node _test_commercial_ui.js",
    "test:finance": "node _test_finance_roi.js",
    "test:decision": "node _test_commercial_decision.js",
    "test:architecture": "node _test_commercial_architecture.js",
    "test:projects": "node _test_project_workspace.js",
    "test:business": "node _test_business_context.js",
    "test:ux": "node _test_ui_flow.js",
    "test:benchmarks": "node _test_benchmark_projects.js",
    "test:templates": "node _test_vertical_templates.js",
    "test:schedules": "node _test_operational_schedule.js",
    "test:machines": "node _test_machine_library.js",
    "test:equipment": "node _test_equipment_library.js",
    "test:threephase": "node _test_three_phase_ui.js",
    "test:clusters": "node _test_three_phase_cluster.js",
    "test:plantscope": "node _test_plant_scoping.js",
    "test:compliance": "node _test_compliance_pack.js",
    "test:ts-setup": "node _test_typescript_setup.js"
  },
  "devDependencies": {
    "playwright": "^1.58.2",
    "typescript": "^5.9.2"
  }
}
