# Premium backend example environment
# Copy the values you need into your real host environment or secret manager.

# Bind publicly on a server host. For local-only dev, 127.0.0.1 is also fine.
HOST=0.0.0.0
PORT=5055

# Current premium v1 source of truth. This repo currently supports manual admin-managed entitlements.
BACKEND_ENTITLEMENT_SOURCE=manual_admin

# Recommended durable storage driver for single-node premium deployment.
# On Node 22.12.x, start the backend with --experimental-sqlite.
BACKEND_STORAGE_DRIVER=sqlite

# Preferred durable sqlite database file.
BACKEND_SQLITE_FILE=/var/lib/pv-premium-sync/premium_sync.sqlite

# Optional persistent runtime data root for JSON mode or as the default parent for sqlite storage.
# Keep this on a mounted disk or server-owned writable path in premium deployment.
BACKEND_DATA_DIR=/var/lib/pv-premium-sync

# Premium v1 operations ownership and retention posture.
BACKEND_BACKUP_ROOT_DIR=/var/backups/pv-premium-sync
BACKEND_BACKUP_SCHEDULE_CRON="10 2 * * *"
BACKEND_BACKUP_KEEP_COUNT=14
BACKEND_BACKUP_KEEP_DAYS=30
BACKEND_BACKUP_OWNER="Platform Ops"
BACKEND_BACKUP_REVIEW_CHANNEL="#pv-premium-ops"
BACKEND_RESTORE_OWNER="Staff Engineer"
BACKEND_RESTORE_DRILL_CADENCE=once-per-release
BACKEND_AUDIT_RETENTION_DAYS=90
BACKEND_DELIVERY_RETENTION_DAYS=90
BACKEND_APPROVAL_RETENTION_DAYS=120
BACKEND_INCIDENT_OWNER="On-call Lead"
BACKEND_INCIDENT_CHANNEL="#pv-incidents"
BACKEND_INCIDENT_RUNBOOK_URL=https://ops.example.com/runbooks/pv-premium

# At least one API key is strongly recommended for premium deployment.
BACKEND_API_KEY=replace-with-a-long-random-value

# Comma-separated list of allowed frontend origins.
BACKEND_ALLOWED_ORIGINS=https://your-static-app.example.com

# Required for signed invite/recovery links in production.
BACKEND_ACTION_LINK_SECRET=replace-with-a-long-random-value

# Optional but recommended pepper material for seat and recovery code hashing.
BACKEND_SEAT_CODE_PEPPER=replace-with-a-long-random-value
BACKEND_RECOVERY_CODE_PEPPER=replace-with-a-long-random-value

# Optional tuning
SEAT_SESSION_TTL_MS=28800000
SEAT_RECOVERY_CODE_TTL_MS=1200000
SEAT_INVITE_CODE_TTL_MS=21600000
ADMIN_ACTION_APPROVAL_TTL_MS=14400000
MAX_BODY_BYTES=262144
MAX_AUDIT_EVENTS_PER_INSTALLATION=120
MAX_SEAT_SIGNIN_ATTEMPTS=5
SEAT_SIGNIN_WINDOW_MS=900000
SEAT_SIGNIN_LOCKOUT_MS=600000
